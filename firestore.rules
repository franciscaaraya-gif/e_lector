rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ========================================================================
    // REGLAS GLOBALES (CRÍTICAS PARA CONSULTAS DE GRUPO)
    // ========================================================================

    // Esta regla permite que la Bandeja de Entrada busque en todos los documentos 'voters'
    // sin importar bajo qué admin o encuesta estén.
    match /{path=**}/voters/{vDocId} {
        // Cualquier usuario autenticado (incluyendo anónimos) puede leer su estado.
        allow read: if request.auth != null;
        
        // Permisos de escritura para el admin y para el proceso de votación (hasVoted)
        allow create: if request.auth != null;
        allow update: if request.auth != null && (
            // El admin puede cambiar todo, el votante solo 'hasVoted'
            (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['hasVoted'])) ||
            (request.auth.uid == resource.data.adminId)
        );
        allow delete: if request.auth != null && request.auth.uid == resource.data.adminId;
    }
    
    // Regla global para votos (permite que cualquier usuario autenticado emita un voto)
    match /{path=**}/votes/{voteId} {
        allow create: if request.auth != null;
        allow read: if request.auth != null; // El admin necesita leerlos para los resultados
    }

    // ========================================================================
    // REGLAS JERÁRQUICAS (ESTRUCTURA ESTÁNDAR)
    // ========================================================================

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /admins/{adminId} {
      allow get: if isSignedIn();
      allow list: if isOwner(adminId);
      allow create: if isOwner(adminId);
      allow update: if isOwner(adminId);
      allow delete: if isOwner(adminId);

      match /polls/{pollId} {
        allow get, list: if isSignedIn();
        allow create, update, delete: if isOwner(adminId);
      }

      match /groups/{groupId} {
        allow read, write: if isOwner(adminId);
      }

      match /lista_completa/{itemId} {
        allow read, write: if isOwner(adminId);
      }

      match /orden_lista/{ordenId} {
        allow read, write: if isOwner(adminId);
      }
      
      match /poll_templates/{templateId} {
        allow read, write: if isOwner(adminId);
      }
    }
    
    // Reglas de utilidad para el sistema
    match /authorizedAdmins/{authId} {
      allow list: if isSignedIn();
    }
    
    match /poll-lookup/{pollId} {
      allow get: if true;
      allow list: if isSignedIn();
      allow create: if isSignedIn();
      allow delete: if isSignedIn();
    }

    match /salas/{salaId} {
      allow get, list: if true;
    }
  }
}