rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // REGLA GLOBAL PARA CONSULTAS DE GRUPO (INDISPENSABLE PARA LA BANDEJA DE ENTRADA)
    match /{path=**}/voters/{vDocId} {
        // Permitimos lectura a cualquiera (incluyendo anónimos) para que la consulta no sea bloqueada por reglas
        // El filtrado real lo hace el motor de búsqueda de Firestore basado en los campos
        allow read: if true;
        
        // Escritura protegida para el admin o para marcar el voto
        allow create: if request.auth != null;
        allow update: if request.auth != null;
        allow delete: if request.auth != null && request.auth.uid == resource.data.adminId;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Regla para que los votantes puedan leer los detalles de la encuesta a la que pertenecen
    match /admins/{adminId}/polls/{pollId} {
      allow get: if true; 
      allow list: if true;
      allow create, update, delete: if isOwner(adminId);
    }

    match /admins/{adminId} {
      allow get: if true;
      allow list: if isOwner(adminId);
      allow create: if isOwner(adminId);
      allow update: if isOwner(adminId);
      allow delete: if isOwner(adminId);

      match /groups/{groupId} {
        allow read, write: if isOwner(adminId);
      }

      match /lista_completa/{itemId} {
        allow read, write: if isOwner(adminId);
      }

      match /orden_lista/{ordenId} {
        allow read, write: if isOwner(adminId);
      }
      
      match /poll_templates/{templateId} {
        allow read, write: if isOwner(adminId);
      }
    }
    
    match /poll-lookup/{pollId} {
      allow get: if true;
      allow list: if isSignedIn();
      allow create: if isSignedIn();
      allow delete: if isSignedIn();
    }

    match /salas/{salaId} {
      allow get, list: if true;
    }
  }
}