rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ========================================================================
    // REGLAS GLOBALES (CRÍTICAS PARA CONSULTAS DE GRUPO)
    // ========================================================================

    // Esta regla permite que la Bandeja de Entrada busque en todos los documentos 'voters'
    // sin importar bajo qué admin o encuesta estén.
    // La hacemos pública para lectura para evitar el error de "Permission Denied" 
    // que a veces enmascara la falta de índices.
    match /{path=**}/voters/{vDocId} {
        allow read: if true;
        
        // Escritura protegida
        allow create: if request.auth != null;
        allow update: if request.auth != null && (
            (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['hasVoted'])) ||
            (request.auth.uid == resource.data.adminId)
        );
        allow delete: if request.auth != null && request.auth.uid == resource.data.adminId;
    }
    
    // Regla global para votos
    match /{path=**}/votes/{voteId} {
        allow create: if request.auth != null;
        allow read: if request.auth != null;
    }

    // ========================================================================
    // REGLAS JERÁRQUICAS (ESTRUCTURA ESTÁNDAR)
    // ========================================================================

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /admins/{adminId} {
      allow get: if true; // Permitir lectura de perfiles admin para identificar salas
      allow list: if isOwner(adminId);
      allow create: if isOwner(adminId);
      allow update: if isOwner(adminId);
      allow delete: if isOwner(adminId);

      match /polls/{pollId} {
        allow get, list: if true; // Las encuestas deben ser legibles para votar
        allow create, update, delete: if isOwner(adminId);
      }

      match /groups/{groupId} {
        allow read, write: if isOwner(adminId);
      }

      match /lista_completa/{itemId} {
        allow read, write: if isOwner(adminId);
      }

      match /orden_lista/{ordenId} {
        allow read, write: if isOwner(adminId);
      }
      
      match /poll_templates/{templateId} {
        allow read, write: if isOwner(adminId);
      }
    }
    
    match /poll-lookup/{pollId} {
      allow get: if true;
      allow list: if isSignedIn();
      allow create: if isSignedIn();
      allow delete: if isSignedIn();
    }

    match /salas/{salaId} {
      allow get, list: if true;
    }
  }
}