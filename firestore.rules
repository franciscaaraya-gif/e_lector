/**
 * Core Philosophy: This ruleset enforces a strict user-ownership model centered around
 * administrators ("admins"). All data, including polls, voter lists, and votes, is
 * hierarchically nested under the specific admin who created it.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ------------------------------------------------------------------------
    // Helper Functions
    // ------------------------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }
    
    function hasValidVoterDataOnCreate(pollId, adminId) {
        return request.resource.data.pollId == pollId && request.resource.data.adminId == adminId;
    }

    // --- Create Request Validation ---

    function hasValidAdminDataOnCreate(adminId) {
      return request.resource.data.id == adminId;
    }

    function hasValidPollDataOnCreate(adminId) {
      return request.resource.data.adminId == adminId;
    }

    function hasValidGroupDataOnCreate(adminId) {
      return request.resource.data.adminId == adminId;
    }

    // --- Update Request Validation ---

    function isAdminDataImmutable() {
      return request.resource.data.id == resource.data.id;
    }

    function isPollDataImmutable() {
      return request.resource.data.adminId == resource.data.adminId;
    }

    function isGroupDataImmutable() {
      return request.resource.data.adminId == resource.data.adminId;
    }

    function isVoterDataImmutable() {
      return request.resource.data.pollId == resource.data.pollId && request.resource.data.adminId == resource.data.adminId;
    }

    // ------------------------------------------------------------------------
    // Collection Group Rules (CRITICAL for Inbox functionality)
    // ------------------------------------------------------------------------

    // This rule MUST be at the top level with {path=**} for collectionGroup queries to work
    match /{path=**}/voters/{voterDocId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && isOwner(request.resource.data.adminId);
        allow update: if isSignedIn() && (isOwner(resource.data.adminId) || (resource.data.voterId == request.auth.uid || isVoterDataImmutable()));
        allow delete: if isSignedIn() && isOwner(resource.data.adminId);
    }
    
    match /{path=**}/votes/{voteId} {
        allow get, list, update, delete: if false;
        allow create: if isSignedIn() && request.resource.data.pollId != null && request.resource.data.adminId != null;
    }

    // ------------------------------------------------------------------------
    // Standard Collection Rules
    // ------------------------------------------------------------------------

    match /admins/{adminId} {
      allow get: if isOwner(adminId) || isSignedIn(); // Allow get for voters checking their admin's polls
      allow list: if false;
      allow create: if isOwner(adminId) && hasValidAdminDataOnCreate(adminId);
      allow update: if isExistingOwner(adminId) && isAdminDataImmutable();
      allow delete: if isExistingOwner(adminId);

        match /polls/{pollId} {
          allow get: if isSignedIn(); 
          allow list: if isOwner(adminId);
          allow create: if isOwner(adminId) && hasValidPollDataOnCreate(adminId);
          allow update: if isExistingOwner(adminId) && isPollDataImmutable();
          allow delete: if isExistingOwner(adminId);

          match /votes/{voteId} {
            allow get, list, delete: if isOwner(adminId);
            allow create, update: if false;
          }
          
          // Subcollection voters (also handled by group rule, but good for direct access)
          match /voters/{vDocId} {
              allow read: if isSignedIn();
          }
        }

        match /groups/{groupId} {
            allow get: if isOwner(adminId);
            allow list: if isOwner(adminId);
            allow create: if isOwner(adminId) && hasValidGroupDataOnCreate(adminId);
            allow update: if isExistingOwner(adminId) && isGroupDataImmutable();
            allow delete: if isExistingOwner(adminId);
        }

        match /lista_completa/{itemId} {
            allow read, write: if isOwner(adminId);
        }

        match /orden_lista/{ordenId} {
            allow read, write: if isOwner(adminId);
        }
        
        match /poll_templates/{templateId} {
            allow read, write: if isOwner(adminId);
        }
    }
    
    match /authorizedAdmins/{authId} {
        allow get: if false;
        allow list: if isSignedIn();
        allow create, update, delete: if false;
    }
    
    match /poll-lookup/{pollId} {
        allow get, list: if true;
        allow create: if isSignedIn() && request.resource.data.adminId == request.auth.uid;
        allow update: if false;
        allow delete: if isSignedIn() && (resource == null || isOwner(resource.data.adminId));
    }

    match /salas/{salaId} {
      allow get: if true;
      allow list: if true;
      allow create, update, delete: if false;
    }
  }
}