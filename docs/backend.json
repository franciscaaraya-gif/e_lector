{
  "entities": {
    "Poll": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Poll",
      "type": "object",
      "description": "Representa una votación con preguntas, opciones y estado.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Identificador único para la votación."
        },
        "question": {
          "type": "string",
          "description": "La pregunta presentada en la votación."
        },
        "options": {
          "type": "array",
          "description": "Opciones disponibles para la pregunta de la votación.",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "text": { "type": "string" }
            },
            "required": ["id", "text"]
          }
        },
        "status": {
          "type": "string",
          "description": "El estado de la votación.",
          "enum": ["pending", "active", "closed"]
        },
        "pollType": {
          "type": "string",
          "description": "El tipo de votación (simple o múltiple).",
          "enum": ["simple", "multiple"]
        },
        "maxSelections": {
          "type": "number",
          "description": "Número máximo de opciones que un votante puede seleccionar en una votación de opción múltiple."
        },
        "groupId": {
            "type": "string",
            "description": "El ID del grupo de votantes asignado."
        },
        "adminId": {
          "type": "string",
          "description": "Referencia al Administrador que creó la votación."
        },
        "createdAt": {
            "type": "string",
            "format": "date-time",
            "description": "Marca de tiempo de cuándo se creó la votación."
        }
      },
      "required": [
        "id",
        "question",
        "options",
        "status",
        "pollType",
        "adminId",
        "createdAt"
      ]
    },
    "Voter": {
      "title": "Voter",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "pollId": { "type": "string" },
        "voterId": { "type": "string" },
        "hasVoted": { "type": "boolean" },
        "adminId": { "type": "string" }
      },
      "required": ["id", "pollId", "voterId", "hasVoted", "adminId"]
    },
    "Vote": {
      "title": "Vote",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "pollId": { "type": "string" },
        "selectedOptions": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["id", "pollId", "selectedOptions"]
    },
    "Admin": {
      "title": "Admin",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "isBombero": { "type": "boolean" }
      },
      "required": ["id", "email"]
    },
    "VoterGroup": {
      "title": "Voter Group",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "adminId": { "type": "string" },
        "voters": { "type": "array", "items": { "type": "object" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "adminId", "voters", "createdAt"]
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous",
      "microsoft.com"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/admins/{adminId}",
        "definition": {
          "entityName": "Admin",
          "schema": { "$ref": "#/backend/entities/Admin" },
          "description": "Administradores."
        }
      },
      {
        "path": "/admins/{adminId}/polls/{pollId}",
        "definition": {
          "entityName": "Poll",
          "schema": { "$ref": "#/backend/entities/Poll" },
          "description": "Votaciones."
        }
      },
      {
        "path": "/admins/{adminId}/groups/{groupId}",
        "definition": {
          "entityName": "VoterGroup",
          "schema": { "$ref": "#/backend/entities/VoterGroup" },
          "description": "Grupos de votantes."
        }
      }
    ]
  }
}